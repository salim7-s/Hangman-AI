# ─────────────────────────────────────────────────────────────────
# Hangman AI — Backend environment variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────────

# Server port (Railway/Render will override this automatically)
PORT=5000

# MongoDB Atlas connection string
# Free tier: https://www.mongodb.com/cloud/atlas/register
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hangman?retryWrites=true&w=majority
# Leave blank to run in-memory mode (game data won't persist between restarts)
MONGO_URI=

# JWT secret — change this to a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret

# JWT token lifespan
JWT_EXPIRES_IN=7d

# Frontend URL (used for CORS and socket.io)
# Local dev: http://localhost:5173
# Vercel production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# Environment
NODE_ENV=development
